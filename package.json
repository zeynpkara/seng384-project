{
  "name": "health-ai",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "frontend:dev": "npm --prefix frontend run dev",
    "backend:dev": "npm --prefix backend run dev",
    "dev": "concurrently \"npm run frontend:dev\" \"npm run backend:dev\"",
    "frontend:install": "npm --prefix frontend install",
    "backend:install": "npm --prefix backend install",
    "install:all": "npm run frontend:install && npm run backend:install",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:push": "npm --prefix backend run db:push",
    "db:seed": "npm --prefix backend run db:seed",
    "setup": "npm run install:all && npm run db:up && npm run db:push && npm run db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
